# plugin-androidtv environment
# For local discovery mode, only PLUGIN_DATA_DIR is required.
# Android TV devices are discovered via mDNS (_googlecast._tcp).
# Copy to .env.local and customize with real values.

# Required: Directory for plugin state storage
PLUGIN_DATA_DIR=/tmp/plugin-androidtv

# Optional: Plugin settings
PLUGIN_ANDROIDTV_ENABLED=true
PLUGIN_ANDROIDTV_LOG_LEVEL=info

# Note: Android TV discovery uses mDNS to find Google Cast enabled devices
# No additional configuration required for local discovery
